# Supabase — project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Resend — https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender domain; falls back to onboarding@resend.dev for testing.
# Only the domain is used — src/lib/mail.ts sends each email type from a
# different local part on this domain (hello/reservations/support/notifications).
EMAIL_FROM="Bhutan Upward Travels <hello@bhutanupwardtravels.bt>"
# Where tour-request notifications are sent
OPERATOR_EMAIL=bhutanupwardtravels@outlook.com
# Resend webhook signing secret — dashboard > Webhooks > add endpoint for /api/webhooks/resend
RESEND_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=https://bhutanupwardtravels.bt
# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# Spam protection on public forms. If unset, the challenge is skipped (dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
